# Docker setup
COMPOSE_FILE=./docker/docker-compose.yml

# App setup
APP_PORT=3000
APP_TITLE=Michelle's Portfolio
APP_DESC=A site full of Michelle Chai's projects.
APP_DATA_LOCATION=/app/public/data.json
FAST_REFRESH=false
CHOKIDAR_USEPOLLING=true

# Github info
GITHUB_EMAIL=email
GITHUB_USERNAME=username
GITHUB_TOKEN=token

# data backend
DATA_BACKEND_ENV=development
DATA_BACKEND_HOST=0.0.0.0
DATA_BACKEND_PORT=3001
DATA_BACKEND_CONSOLE_LOG=1

# database
DB_TYPE=mongo+srv
DB_USERNAME=root
DB_PASSWORD=mySecretPassword
DB_HOST=mongodb
DB_DATA=app

# data frontend
DATA_FRONTEND_PORT=8080
